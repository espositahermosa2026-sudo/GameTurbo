<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/gt_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="TURBO HUD"
            android:textColor="@color/gt_accent"
            android:textSize="26sp"
            android:textStyle="bold"
            android:letterSpacing="0.08"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="GAME TURBO · MODO RENDIMIENTO"
            android:textColor="@color/gt_text_secondary"
            android:textSize="10sp"
            android:letterSpacing="0.06"
            android:layout_marginBottom="16dp" />

        <TextView
            android:id="@+id/statusText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_card_button"
            android:padding="12dp"
            android:textColor="@color/gt_text_secondary"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:layout_marginBottom="18dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="18dp">

            <TextView
                android:id="@+id/turboDial"
                android:layout_width="150dp"
                android:layout_height="150dp"
                android:background="@drawable/bg_turbo_dial"
                android:gravity="center"
                android:text="⚡\nTURBO"
                android:textColor="@color/gt_text_primary"
                android:textSize="15sp"
                android:textStyle="bold"
                android:letterSpacing="0.05"
                android:clickable="true"
                android:focusable="true" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_card_button"
            android:paddingStart="18dp"
            android:paddingEnd="14dp"
            android:layout_marginBottom="10dp">

            <TextView
                android:layout_width="28dp"
                android:layout_height="wrap_content"
                android:text="🔕"
                android:textSize="18sp" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="No Molestar"
                android:textColor="@color/gt_text_primary"
                android:textSize="14sp" />

            <Switch
                android:id="@+id/dndSwitch"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:thumbTint="@color/switch_thumb_color"
                android:trackTint="@color/switch_track_color" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_card_button"
            android:paddingStart="18dp"
            android:paddingEnd="14dp"
            android:layout_marginBottom="10dp">

            <TextView
                android:layout_width="28dp"
                android:layout_height="wrap_content"
                android:text="🎮"
                android:textSize="18sp" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Panel Flotante"
                android:textColor="@color/gt_text_primary"
                android:textSize="14sp" />

            <Switch
                android:id="@+id/overlaySwitch"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:thumbTint="@color/switch_thumb_color"
                android:trackTint="@color/switch_track_color" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/floatingAppRow"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_card_button"
            android:paddingStart="18dp"
            android:paddingEnd="18dp"
            android:layout_marginBottom="10dp"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:layout_width="28dp"
                android:layout_height="wrap_content"
                android:text="🪟"
                android:textSize="18sp" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Ventana Flotante"
                android:textColor="@color/gt_text_primary"
                android:textSize="14sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="›"
                android:textColor="@color/gt_accent"
                android:textSize="20sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_card_button"
            android:paddingStart="18dp"
            android:paddingEnd="14dp"
            android:layout_marginBottom="10dp">

            <TextView
                android:layout_width="28dp"
                android:layout_height="wrap_content"
                android:text="⏺"
                android:textSize="18sp" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Grabar Pantalla"
                android:textColor="@color/gt_text_primary"
                android:textSize="14sp" />

            <Switch
                android:id="@+id/recordSwitch"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:thumbTint="@color/switch_thumb_color"
                android:trackTint="@color/switch_track_color" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_card_button"
            android:paddingStart="18dp"
            android:paddingEnd="14dp">

            <TextView
                android:layout_width="28dp"
                android:layout_height="wrap_content"
                android:text="🎯"
                android:textSize="18sp" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Auto-activar en Juegos"
                android:textColor="@color/gt_text_primary"
                android:textSize="14sp" />

            <Switch
                android:id="@+id/autoDetectSwitch"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:thumbTint="@color/switch_thumb_color"
                android:trackTint="@color/switch_track_color" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
